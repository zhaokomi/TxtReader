# 强制所有文本文件使用 LF 换行符（跨平台兼容）
* text=auto
# gradlew 必须用 LF
gradlew text eol=lf
# gradlew.bat 用 CRLF
*.bat text eol=crlf
# Java/Kotlin/Android 配置文件都用 LF
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# 二进制文件不过滤
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.webp binary
