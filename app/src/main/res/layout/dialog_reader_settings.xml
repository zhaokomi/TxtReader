<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:paddingBottom="32dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="阅读设置"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="20dp" />

    <!-- 字体大小 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="字体大小"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurface" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <SeekBar
            android:id="@+id/seekFontSize"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:max="100" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="22sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvFontSizeValue"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="18sp"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary" />
    </LinearLayout>

    <!-- 行间距 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="行间距"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurface" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp">

        <SeekBar
            android:id="@+id/seekLineSpacing"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:max="100" />

        <TextView
            android:id="@+id/tvLineSpacingValue"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1.8倍"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary" />
    </LinearLayout>

    <!-- 主题选择 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="背景主题"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnTheme0"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="#FAFAFA"
            android:text="白昼"
            android:textColor="#222222"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTheme1"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="#CCE8CF"
            android:text="护眼"
            android:textColor="#1A3A1A"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTheme2"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="#F5E6C8"
            android:text="羊皮纸"
            android:textColor="#3D2B1F"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTheme3"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="#2D2D2D"
            android:text="深色"
            android:textColor="#CCCCCC"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTheme4"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="#0D0D0D"
            android:text="夜间"
            android:textColor="#888888"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
